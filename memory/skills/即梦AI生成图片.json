{
  "skill_name": "即梦AI生成图片",
  "description": "通过即梦AI网站自动生成图片，文生图功能。注意：每次使用需要用户先扫码登录",
  "version": "1.0.1",
  "trigger_keywords": ["即梦生成图片", "AI生成图片", "用即梦做图", "jimeng生成"],
  "platform": "jimeng.jianying.com",
  "url": "https://jimeng.jianying.com/ai-tool/home",

  "mcp_required": "puppeteer-stealth",

  "usage": {
    "step1_login": "用户先在浏览器中打开即梦AI并扫码登录",
    "step2_navigate": "使用 browser_navigate 导航到 https://jimeng.jianying.com/ai-tool/home",
    "step3_explore": "点击'AI绘画'卡片进入文生图页面",
    "step4_generate": "输入提示词并生成图片"
  },

  "steps": [
    {
      "step": 1,
      "action": "用户登录",
      "description": "提示用户在浏览器中扫码登录即梦AI",
      "manual": true
    },
    {
      "step": 2,
      "action": "启动浏览器",
      "tool": "browser_launch",
      "params": { "profile": "default" }
    },
    {
      "step": 3,
      "action": "导航到首页",
      "tool": "browser_navigate",
      "params": { "url": "https://jimeng.jianying.com/ai-tool/home" }
    },
    {
      "step": 4,
      "action": "等待页面加载并截图确认登录状态",
      "tool": "browser_snapshot"
    },
    {
      "step": 5,
      "action": "点击进入AI绘画/文生图页面",
      "description": "点击首页的'AI绘画'功能卡片",
      "tool": "browser_click",
      "selector": "[class*='card'], [class*='item']"
    },
    {
      "step": 6,
      "action": "等待文生图页面加载",
      "tool": "wait",
      "timeout": 5000
    },
    {
      "step": 7,
      "action": "点击文本框激活输入区域",
      "tool": "browser_click",
      "selector": "textarea, [class*='input'], [contenteditable='true']"
    },
    {
      "step": 8,
      "action": "输入提示词",
      "tool": "browser_type",
      "selector": "textarea",
      "params": { "text": "${prompt}" }
    },
    {
      "step": 9,
      "action": "选择图片风格（可选）",
      "tool": "browser_click",
      "selector": "[class*='style'], [class*='model']"
    },
    {
      "step": 10,
      "action": "选择图片比例（可选）",
      "tool": "browser_click",
      "selector": "[class*='ratio'], [class*='size']"
    },
    {
      "step": 11,
      "action": "点击生成按钮",
      "tool": "browser_click",
      "selector": "button:has-text('生成'), button.primary, [class*='generate']"
    },
    {
      "step": 12,
      "action": "等待图片生成完成",
      "tool": "wait",
      "timeout": 90000
    },
    {
      "step": 13,
      "action": "截图保存生成的图片",
      "tool": "browser_screenshot",
      "params": { "filePath": "aios/images/jimeng-${timestamp}.png" }
    },
    {
      "step": 14,
      "action": "关闭浏览器",
      "tool": "browser_close"
    }
  ],

  "style_presets": {
    "写实": "写实风格，高清逼真",
    "卡通": "卡通插画风格，可爱有趣",
    "漫画": "漫画风格，线条分明",
    "插画": "商业插画风格，精美细腻",
    "唯美": "唯美梦幻风格，浪漫优雅"
  },

  "aspect_ratios": {
    "3:4": "竖版推荐，小红书最佳",
    "1:1": "方形图文",
    "16:9": "横版"
  },

  "prompt_examples": [
    "粉色和浅紫色渐变背景，梦幻光斑效果，马卡龙配色，浪漫温馨氛围",
    "一个女孩安静看书的剪影，暖黄和橙色渐变背景，日落时分氛围",
    "极简现代设计，几何图形装饰，浅色专业背景"
  ],

  "error_handling": {
    "未登录": "提示用户扫码登录后继续",
    "生成失败": "重试1次，仍失败返回错误信息",
    "下载失败": "提示用户手动保存"
  },

  "output": {
    "directory": "aios/images/",
    "filename_pattern": "jimeng-${timestamp}.png"
  },

  "anti_detection": {
    "random_delay": "3000-8000",
    "human_behavior": true,
    "stealth_enabled": true
  },

  "notes": [
    "必须使用 puppeteer-stealth MCP",
    "输入提示词后等待3-5秒再点击生成",
    "生成图片需要等待30-90秒",
    "如果遇到验证码需要用户手动处理"
  ]
}
