{
  "name": "playwright-browser-mcp",
  "version": "1.0.0",
  "type": "module",
  "description": "Playwright MCP server for browser automation with profile and CDP support",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "build": "node -e \"const fs=require('fs'); if (fs.rmSync) { fs.rmSync('dist',{recursive:true,force:true}); } else if (fs.existsSync('dist')) { fs.rmdirSync('dist',{recursive:true}); }\" && tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "test:contextdb": "tsx --test tests/contextdb.test.ts",
    "bench:contextdb:refs": "tsx scripts/contextdb-refs-benchmark.ts",
    "bench:contextdb:refs:ci": "tsx scripts/contextdb-refs-benchmark.ts --events 1200 --refs-pool 180 --queries 240 --warmup 40 --json-out test-results/contextdb-refs-bench.json",
    "bench:contextdb:refs:gate": "tsx scripts/contextdb-refs-benchmark-gate.ts --input test-results/contextdb-refs-bench.json",
    "contextdb": "tsx src/contextdb/cli.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^12.9.0",
    "playwright": "^1.58.2",
    "playwright-core": "^1.58.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
